# UltraThreads 部署配置文件
# 复制此文件为 .env 并修改配置

# ============================================
# 数据库配置
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root1234
MYSQL_DBNAME=course

# ============================================
# 认证配置
# ============================================
# 密码盐值（用于加密密码）
PASSWORD_SALT=ultrathreads-password-salt-change-in-production

# JWT 签名密钥（用于生成 token）
JWT_SIGNING_KEY=ultrathreads-jwt-signing-key-change-in-production

# ============================================
# 应用配置
# ============================================
# 运行环境: local, staging, prod
APP_ENV=local

# HTTP 服务配置
HTTP_HOST=localhost
HTTP_PORT=8000

# ============================================
# SMTP 邮件配置
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=noreply@ultrathreads.com
SMTP_PASSWORD=

# ============================================
# 文件存储配置（MinIO/S3）
# ============================================
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=ultrathreads

# ============================================
# 支付配置（Fondy）
# ============================================
FONDY_MERCHANT_ID=
FONDY_MERCHANT_PASSWORD=
FONDY_CALLBACK_URL=http://localhost:8000/api/v1/payment/callback

# ============================================
# 前端配置
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
