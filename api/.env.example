# UltraThreads 环境配置文件
# 复制此文件为 .env 并修改配置

# ============================================
# 应用配置
# ============================================
APP_ENV=local

# ============================================
# HTTP 服务配置
# ============================================
HTTP_PORT=8000
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
HTTP_MAX_HEADER_MEGABYTES=1

# ============================================
# 数据库配置 (MySQL)
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root1234
MYSQL_DBNAME=course

# ============================================
# 缓存配置
# ============================================
CACHE_TTL=60s

# ============================================
# 认证配置
# ============================================
# 密码盐值（用于加密密码）
PASSWORD_SALT=your-password-salt-change-in-production

# JWT 签名密钥（用于生成 token）
JWT_SIGNING_KEY=your-jwt-signing-key-change-in-production

# Access Token 有效期
ACCESS_TOKEN_TTL=2h

# Refresh Token 有效期
REFRESH_TOKEN_TTL=720h

# 验证码长度
VERIFICATION_CODE_LENGTH=8

# ============================================
# 文件存储配置 (MinIO/S3)
# ============================================
STORAGE_ENDPOINT=ams3.digitaloceanspaces.com
STORAGE_BUCKET=courses
STORAGE_ACCESS_KEY=your-access-key-here
STORAGE_SECRET_KEY=your-secret-key-here

# ============================================
# 限流配置
# ============================================
LIMITER_RPS=10
LIMITER_BURST=20
LIMITER_TTL=10m

# ============================================
# SMTP 邮件配置
# ============================================
SMTP_HOST=mail.privateemail.com
SMTP_PORT=587
SMTP_FROM=no-reply@ultrathreads.me
SMTP_PASSWORD=

# ============================================
# 邮件模板配置
# ============================================
EMAIL_TEMPLATE_VERIFICATION=./templates/verification_email.html
EMAIL_TEMPLATE_PURCHASE_SUCCESSFUL=./templates/purchase_successful.html
EMAIL_SUBJECT_VERIFICATION=Спасибо за регистрацию, %s!
EMAIL_SUBJECT_PURCHASE_SUCCESSFUL=Покупка прошла успешно!

# ============================================
# 支付配置 (Fondy)
# ============================================
FONDY_CALLBACK_URL=
